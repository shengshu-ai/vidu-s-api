# Vidu S1 API quickstart environment.
# Copy this file to .env and replace the placeholders before running examples.

# API key from https://platform.vidu.cn/api-keys or https://platform.vidu.com/api-keys.
VIDU_API_KEY=vda_your_api_key_here

# Use api.vidu.cn for China, api.vidu.com for overseas.
VIDU_HOST=api.vidu.cn

# Node quickstart server.
NODE_QUICKSTART_PORT=8787

# Default live-session payload used by examples/node-quickstart.
VIDU_CALL_MODE=video
VIDU_AVATAR_IMAGE_URI=https://image01.vidu.zone/vidu/media-asset/vidu-image-3368107666190008.png
VIDU_AVATAR_PERSONA=You face the camera like a live video chat, keeping natural eye contact and lively expressions. Normally you are soft, cute, gentle, and sweet; in rap mode, you become confident and sharp, rap into the mic, move with the beat, and use strong but natural hand gestures. Cozy indoor music-room background. No text, watermark, extra people, poster-like stage framing, or abnormal limbs.
VIDU_AVATAR_NAME=Tina
VIDU_AVATAR_VOICE=Tina
